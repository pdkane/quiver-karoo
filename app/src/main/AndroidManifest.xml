<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The extension reaches quiver.fyi through the Karoo System's managed HTTP
         (OnHttpResponse.MakeHttpRequest), so no INTERNET permission is required for
         that path. INTERNET is declared for defensiveness / future direct calls. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- The sync service promotes itself to the foreground so the Karoo System can't
         tear it down mid-ride (a bound-only extension with no data types has no other
         reason to stay alive). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <!-- Richer sideload + in-device "Update" via the Companion app. Points at the
             manifest.json published with each GitHub release. -->
        <meta-data
            android:name="io.hammerhead.karooext.MANIFEST_URL"
            android:value="https://github.com/quiver-fyi/quiver-karoo/releases/latest/download/manifest.json" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".extension.QuiverExtension"
            android:exported="true"
            android:foregroundServiceType="dataSync"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="io.hammerhead.karooext.KAROO_EXTENSION" />
            </intent-filter>
            <meta-data
                android:name="io.hammerhead.karooext.EXTENSION_INFO"
                android:resource="@xml/extension_info" />
        </service>
    </application>

</manifest>
