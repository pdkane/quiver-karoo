<?xml version="1.0" encoding="utf-8"?>
<!--
  Quiver Karoo extension descriptor.

  id: stable extension id (no dots) — must match QuiverExtension("quiver", ...).
  scansDevices=false: v1 does not add itself as a sensor; it observes ride/state
  events and syncs mileage to the rider's Quiver garage in the background.
-->
<ExtensionInfo
    displayName="@string/extension_name"
    icon="@drawable/ic_launcher_foreground"
    id="quiver"
    scansDevices="false" />
